# Unified Git Ignore for Clans & Branches Monorepo

# Root ignores
.DS_Store
*.pem
*.tsbuildinfo

# Frontend ignores
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.env*
frontend/next-env.d.ts

# Backend ignores
backend/venv/
backend/__pycache__/
backend/app/__pycache__/
backend/app/routes/__pycache__/
backend/*.db
backend/.env
backend/static/uploads/*
